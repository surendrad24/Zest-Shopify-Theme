<style>
  .ss-colv3__container{
      width: 100%;
      max-width: 1370px;
      margin: 0 auto;
      padding: 0 15px;
      padding-top: {{section.settings.padding_desktop_top}}px;
      padding-bottom: {{section.settings.padding_desktop_bottom}}px;
  }
  .ss-colv3__grid--title{
    font-size: 20px;
    margin-bottom: 15px;
  }
  .ss-colv3__grid{
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      grid-template-rows: repeat(6, 1fr);
      gap: 10px;
      max-height: 90vh;
  }
  .ss-colv3__grid--item{
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 10px;
  }
  .ss-colv3__grid--item:nth-child(1){
      grid-column: span 3 / span 3;
      grid-row: span 6 / span 6;
  }
  .ss-colv3__grid--item:nth-child(2){
      grid-row: span 3 / span 3;
      grid-column-start: 4;
  }
  .ss-colv3__grid--item:nth-child(3){
      grid-row: span 3 / span 3;
      grid-column-start: 5;
  }
  .ss-colv3__grid--item:nth-child(4){
      grid-row: span 3 / span 3;
      grid-column-start: 4;
      grid-row-start: 4;
  }
  .ss-colv3__grid--item:nth-child(5){
      grid-row: span 3 / span 3;
      grid-column-start: 5;
      grid-row-start: 4;
  }

  .ss-colv3__grid--item .ss-colv3__grid--image{
      display: inline-block;
      width: 100%;
      height: 100%;
      /* aspect-ratio: 0.76/1; */
  }
  .ss-colv3__grid--item:nth-child(1) .ss-colv3__grid--image{
      aspect-ratio: auto;
  }
  .ss-colv3__grid--item .ss-colv3__grid--image{
    width: 100%;
  }
  .ss-colv3__grid--item:nth-child(2) .ss-colv3__grid--image,
  .ss-colv3__grid--item:nth-child(3) .ss-colv3__grid--image,
  .ss-colv3__grid--item:nth-child(4) .ss-colv3__grid--image,
  .ss-colv3__grid--item:nth-child(5) .ss-colv3__grid--image{
    max-height: 92%;
    overflow: hidden;
  }
  .ss-colv3__grid--image img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      /* position: absolute;
      top: 0;
      left: 0; */
  }
  .ss-colv3__grid--cta{
    font-size: 13px;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 5px;
  }
  @media screen and (max-width: 768px){
      .ss-colv3__container{
        padding-top: {{section.settings.padding_mobile_top}}px;
        padding-bottom: {{section.settings.padding_mobile_bottom}}px;
      }
      .ss-colv3__grid{
          grid-template-columns: repeat(2, 1fr);
          grid-template-rows: repeat(6, 1fr);
          row-gap: 20px;
          column-gap: 30px;
          aspect-ratio: unset;
      }
      .ss-colv3__grid--item:nth-child(1){
          grid-column: span 2 / span 2;
          grid-row: span 2 / span 2;
          margin-bottom: 32px;
      }
      .ss-colv3__grid--item:nth-child(2){
          grid-column-start: unset;
          grid-row: span 2 / span 2;
          grid-row-start: 3;
      }
      .ss-colv3__grid--item:nth-child(3){
          grid-column-start: unset;
          grid-row: span 2 / span 2;
          grid-row-start: 3;
      }
      .ss-colv3__grid--item:nth-child(4){
          grid-column-start: unset;
          grid-row: span 2 / span 2;
          grid-row-start: 5;
      }
      .ss-colv3__grid--item:nth-child(5){
          grid-column-start: unset;
          grid-row: span 2 / span 2;
          grid-row-start: 5;
      }
      .ss-colv3__grid--item:nth-child(2) .ss-colv3__grid--image,
      .ss-colv3__grid--item:nth-child(3) .ss-colv3__grid--image,
      .ss-colv3__grid--item:nth-child(4) .ss-colv3__grid--image,
      .ss-colv3__grid--item:nth-child(5) .ss-colv3__grid--image{
        max-height: 100%;
      }
  }
  @media screen and (max-width: 768px){
      .ss-colv3__grid{
          row-gap: 25px;
          column-gap: 10px;
      }
  }


</style>



<div class="ss-colv3__container">
  <h2 class="ss-colv3__grid--title">{{ section.settings.title }}</h2>
  <div class="ss-colv3__grid">
    <div class="ss-colv3__grid--item">
      <a href="/collections/{{ section.settings.col_1.handle }}" class="ss-colv3__grid--image">
        {% if section.settings.col_1_image != blank %}
          <img
            src="{{ section.settings.col_1_image | image_url }}"
            alt="{{ section.settings.col_1.title }}"
            width=""
            height=""
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </a>
      <a href="/collections/{{ section.settings.col_1.handle }}" class="ss-colv3__grid--cta">
        {{- section.settings.col_1.title -}}
      </a>
    </div>
