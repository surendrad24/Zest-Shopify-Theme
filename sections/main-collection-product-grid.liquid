        },
        {
          "value": "infinite",
          "label": "t:sections.main-collection-product-grid.settings.paginate_type.options.option_3"
        }
      ],
      "default": "number"
    },
    {
      "type": "header",
      "content": "t:sections.common.section_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
