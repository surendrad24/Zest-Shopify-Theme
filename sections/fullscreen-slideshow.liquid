{% stylesheet %}
.fullscreen-slideshow {
  position: relative;
  width: 100%;
  height: 95vh;
  overflow: hidden;
}

/* @media screen and (max-width: 768px) {
    .fullscreen-slideshow {
        margin-top: 20px;
    }  */
}

.fullscreen-slideshow__slide {
  position: absolute;   /* stack on top of each other */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0;           /* hide by default */
  transition: opacity 1s ease-in-out;
  z-index: 0;
}

.fullscreen-slideshow__image {
  width: 100%;
  height: 100vh;
  object-fit: cover; /* fills the area, crops minimally */
  object-position: top center; /* always keep top area visible */

}

.fullscreen-slideshow__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.2);
}

.slideshow__content-wrapper {
  position: absolute;
  top: 48vh;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 6rem 2rem;
  text-align: center;
}


.fullscreen-slideshow__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  color: #fff;
  padding: 20px;
  max-width: 32rem;
  margin: 0 auto;
}

.fullscreen-slideshow__heading {
  font-size: calc(var(--font-hxl-size) * 0.7);
  font-weight: bold;
  font-family: var(--font-mega-family);
  color: #fff;
  line-height: 0.95;
  letter-spacing: 0.04em;
  text-shadow: 0 10px 24px rgba(0, 0, 0, 0.24);
}

.fullscreen-slideshow__subheading {
  margin-top: 12px;
  font-size: 1.2rem;
  max-width: 28rem;
  text-shadow: 0 4px 18px rgba(0, 0, 0, 0.24);
}

.fullscreen-slideshow__button {
  margin-top: 24px;
  padding: 14px 34px;
  font-size: 14px;
  background: #fff;
  border-color: #fff;
  color: #000;
  text-decoration: none;
  border-radius: 999px;
  font-weight: bold;
  font-family: var(--font-btn-family);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  transition: transform 0.25s ease, box-shadow 0.25s ease, background-color 0.25s ease, color 0.25s ease;
  box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
}

.fullscreen-slideshow__button:hover {
  transform: translateY(-2px);
  box-shadow: 0 18px 34px rgba(0, 0, 0, 0.22);
}

.fullscreen-slideshow__button:focus-visible {
  outline: 2px solid #fff;
  outline-offset: 3px;
}

.fullscreen-slideshow {
  position: relative;
  width: 100%;
  height: 95vh;
  overflow: hidden;
}



.fullscreen-slideshow__slide.active {
  opacity: 1;           /* show active slide */
  z-index: 1;
}

@media screen and (max-width: 767px) {
  .fullscreen-slideshow {
    height: 88vh;
  }

  .fullscreen-slideshow__image {
    height: 88vh;
  }

  .slideshow__content-wrapper {
    top: auto;
    bottom: 0;
    padding: 2rem 1.25rem 3rem;
  }

  .fullscreen-slideshow__content {
    max-width: 22rem;
    padding: 0;
  }

  .fullscreen-slideshow__heading {
    font-size: clamp(2rem, 10vw, 3.3rem);
  }

  .fullscreen-slideshow__subheading {
    font-size: 1rem;
  }

  .fullscreen-slideshow__button {
    width: min(100%, 16rem);
    padding: 13px 24px;
  }
}



{% endstylesheet %}

<div class="fullscreen-slideshow" >
  {% for block in section.blocks %}
    <div class="fullscreen-slideshow__slide">
      <picture>
        {% if block.settings.mobile_image != blank %}
          <source 
            media="(max-width: 767px)" 
            srcset="{{ block.settings.mobile_image | image_url: width: 800 }}">
        {% endif %}
        {% if block.settings.desktop_image != blank %}
          <img 
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}" 
            alt="{{ block.settings.heading | escape }}" 
            class="fullscreen-slideshow__image">
        {% endif %}
      </picture>

      <div class="fullscreen-slideshow__overlay"></div>
      <div class="slideshow__content-wrapper">
        <div class="fullscreen-slideshow__content">
            {% if block.settings.heading != blank %}
            <h1 class="fullscreen-slideshow__heading">{{ block.settings.heading }}</h1>
            {% endif %}
            {% if block.settings.subheading != blank %}
            <p class="fullscreen-slideshow__subheading">{{ block.settings.subheading }}</p>
            {% endif %}
            {% if block.settings.button_label != blank %}
            <a href="{{ block.settings.button_link }}" class="fullscreen-slideshow__button">
                {{ block.settings.button_label }}
            </a>
            {% endif %}
        </div>
      </div>
    </div>
  {% endfor %}
</div>


<script>
document.addEventListener("DOMContentLoaded", function() {
  const slides = document.querySelectorAll(".fullscreen-slideshow__slide");

  if (slides.length === 0) return;

  let index = 0;

  function showSlide(i) {
    slides.forEach((slide, idx) => {
      slide.classList.toggle("active", idx === i);
    });
  }

  function nextSlide() {
    index = (index + 1) % slides.length;
    showSlide(index);
  }

  showSlide(index);

  if (slides.length > 1) {
    setInterval(nextSlide, 5000);
  }
});
</script>


{% schema %}
{
  "name": "Fullscreen Slideshow",
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fullscreen Slideshow",
      "category": "Hero"
    }
  ]
}
{% endschema %}
