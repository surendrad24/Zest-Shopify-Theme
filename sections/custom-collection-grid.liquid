{% comment %}
  Hot Categories Section
  Displays a grid of featured product categories with images
{% endcomment %}

{%- liquid
  assign section_id = 'hot-categories-' | append: section.id
-%}

<section id="{{ section_id }}" class="hot-categories-section">
  <div class="container">
    {% if section.settings.heading != blank %}
      <div class="hot-categories-header">
        <h2 class="hot-categories-title">{{ section.settings.heading }}</h2>
        {% if section.settings.description != blank %}
          <p class="hot-categories-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="hot-categories-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'category_large' %}
            <div class="category-item category-large" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.category_url | default: '#' }}" class="category-link">
                <div class="category-image-wrapper">
                  {% if block.settings.category_image != blank %}
                    <img 
                      src="{{ block.settings.category_image | image_url: width: 800 }}"
                      alt="{{ block.settings.category_title | escape }}"
                      class="category-image"
                      loading="lazy"
                      width="800"
                      height="600"
                    >
                  {% else %}
                    <div class="category-placeholder">
                      <span>{{ block.settings.category_title }}</span>
                    </div>
                  {% endif %}
                  
                  {% if block.settings.category_title != blank %}
                    <div class="category-overlay">
                      <h3 class="category-title">{{ block.settings.category_title }}</h3>
                      {% if block.settings.category_subtitle != blank %}
                        <p class="category-subtitle">{{ block.settings.category_subtitle }}</p>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </a>
            </div>

          {% when 'category_small' %}
            <div class="category-item category-small" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.category_url | default: '#' }}" class="category-link">
                <div class="category-image-wrapper">
                  {% if block.settings.category_image != blank %}
                    <img 
                      src="{{ block.settings.category_image | image_url: width: 400 }}"
                      alt="{{ block.settings.category_title | escape }}"
                      class="category-image"
                      loading="lazy"
                      width="400"
                      height="300"
                    >
                  {% else %}
                    <div class="category-placeholder">
                      <span>{{ block.settings.category_title }}</span>
                    </div>
                  {% endif %}
                  
                  {% if block.settings.category_title != blank %}
                    <div class="category-overlay">
                      <h3 class="category-title">{{ block.settings.category_title }}</h3>
                      {% if block.settings.category_subtitle != blank %}
                        <p class="category-subtitle">{{ block.settings.category_subtitle }}</p>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </a>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .hot-categories-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
  }

  .hot-categories-section .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hot-categories-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .hot-categories-title {
    font-size: 2.5rem;
    font-weight: 600;
    margin: 0 0 15px;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.02em;
  }

  .hot-categories-description {
    font-size: 1.1rem;
    color: {{ section.settings.text_color }};
    margin: 0;
    opacity: 0.8;
  }

  .hot-categories-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 300px);
    gap: 20px;
    margin-bottom: 0;
  }

  /* Grid layout matching the reference */
  .category-item:nth-child(1) {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .category-item:nth-child(2) {
    grid-column: 3 / 5;
    grid-row: 1 / 2;
  }

  .category-item:nth-child(3) {
    grid-column: 3 / 4;
    grid-row: 2 / 3;
  }

  .category-item:nth-child(4) {
    grid-column: 4 / 5;
    grid-row: 2 / 3;
  }

  .category-item:nth-child(5) {
    grid-column: 1 / 3;
    grid-row: 3 / 4;
  }

  .category-item:nth-child(6) {
    grid-column: 3 / 5;
    grid-row: 3 / 4;
  }

  .category-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background: #f5f5f5;
  }

  .category-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .category-link {
    display: block;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .category-image-wrapper {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  .category-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .category-item:hover .category-image {
    transform: scale(1.05);
  }

  .category-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f5f5f5, #e0e0e0);
    color: #666;
    font-weight: 500;
  }

  .category-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    padding: 30px 20px 20px;
    color: white;
  }

  .category-title {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 0 0 5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .category-subtitle {
    font-size: 0.9rem;
    margin: 0;
    opacity: 0.9;
  }

  /* Tablet styles */
  @media (max-width: 1024px) {
    .hot-categories-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 250px);
      gap: 15px;
    }

    .category-item:nth-child(1) {
      grid-column: 1 / 3;
      grid-row: 1 / 2;
    }

    .category-item:nth-child(2) {
      grid-column: 3 / 4;
      grid-row: 1 / 3;
    }

    .category-item:nth-child(3) {
      grid-column: 1 / 2;
      grid-row: 2 / 3;
    }

    .category-item:nth-child(4) {
      grid-column: 2 / 3;
      grid-row: 2 / 3;
    }

    .category-item:nth-child(5) {
      grid-column: 1 / 2;
      grid-row: 3 / 4;
    }

    .category-item:nth-child(6) {
      grid-column: 2 / 4;
      grid-row: 3 / 4;
    }
  }

  /* Mobile styles */
  @media (max-width: 768px) {
    .hot-categories-section {
      padding: {{ section.settings.padding_top | divided_by: 2 }}px 0 {{ section.settings.padding_bottom | divided_by: 2 }}px;
    }

    .hot-categories-section .container {
      padding: 0 15px;
    }

    .hot-categories-header {
      margin-bottom: 30px;
    }

    .hot-categories-title {
      font-size: 2rem;
    }

    .hot-categories-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(4, 200px);
      gap: 12px;
    }

    .category-item:nth-child(1) {
      grid-column: 1 / 3;
      grid-row: 1 / 2;
    }

    .category-item:nth-child(2) {
      grid-column: 1 / 3;
      grid-row: 2 / 3;
    }

    .category-item:nth-child(3) {
      grid-column: 1 / 2;
      grid-row: 3 / 4;
    }

    .category-item:nth-child(4) {
      grid-column: 2 / 3;
      grid-row: 3 / 4;
    }

    .category-item:nth-child(5) {
      grid-column: 1 / 2;
      grid-row: 4 / 5;
    }

    .category-item:nth-child(6) {
      grid-column: 2 / 3;
      grid-row: 4 / 5;
    }

    .category-overlay {
      padding: 20px 15px 15px;
    }

    .category-title {
      font-size: 1.1rem;
    }

    .category-subtitle {
      font-size: 0.8rem;
    }
  }

  @media (max-width: 480px) {
    .hot-categories-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(6, 180px);
    }

    .category-item:nth-child(1),
    .category-item:nth-child(2),
    .category-item:nth-child(3),
    .category-item:nth-child(4),
    .category-item:nth-child(5),
    .category-item:nth-child(6) {
      grid-column: 1 / 2;
      grid-row: auto;
    }
  }
</style>

{% schema %}
{
  "name": "Hot Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hot Categories"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "category_large",
      "name": "Large Category",
      "settings": [
        {
          "type": "text",
          "id": "category_title",
          "label": "Category Title",
          "default": "Best Sellers"
        },
        {
          "type": "text",
          "id": "category_subtitle",
          "label": "Category Subtitle"
        },
        {
          "type": "image_picker",
          "id": "category_image",
          "label": "Category Image"
        },
        {
          "type": "url",
          "id": "category_url",
          "label": "Category URL"
        }
      ]
    },
    {
      "type": "category_small",
      "name": "Small Category",
      "settings": [
        {
          "type": "text",
          "id": "category_title",
          "label": "Category Title",
          "default": "Dresses"
        },
        {
          "type": "text",
          "id": "category_subtitle",
          "label": "Category Subtitle"
        },
        {
          "type": "image_picker",
          "id": "category_image",
          "label": "Category Image"
        },
        {
          "type": "url",
          "id": "category_url",
          "label": "Category URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hot Categories",
      "blocks": [
        {
          "type": "category_large",
          "settings": {
            "category_title": "Best Sellers"
          }
        },
        {
          "type": "category_small",
          "settings": {
            "category_title": "Dresses"
          }
        },
        {
          "type": "category_small",
          "settings": {
            "category_title": "Matching Sets"
          }
        },
        {
          "type": "category_small",
          "settings": {
            "category_title": "Tops"
          }
        },
        {
          "type": "category_small",
          "settings": {
            "category_title": "Bottoms"
          }
        },
        {
          "type": "category_large",
          "settings": {
            "category_title": "New Arrivals"
          }
        }
      ]
    }
  ]
}
{% endschema %}
