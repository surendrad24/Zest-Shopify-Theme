<style>
  .sol-colv2__container{
      max-width: 1370px;
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      padding: 125px 15px 60px;
      padding-top:{{section.settings.padding_desktop_top}}px;
      padding-bottom:{{section.settings.padding_desktop_bottom}}px;
  }
  .sol-colv2__grid{
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-column-gap: 30px;
  }
  .sol-colv2__grid--item{
      width: 100%;
      padding: 0 15px 0 25px;
      display: flex;
      flex-direction: column;
      gap: 20px;
  }
  .sol-colv2__grid--item--image{
      width: 100%;
      aspect-ratio: 1.06/1;
      position: relative;
      overflow: hidden;
      display: inline-block;
  }
  .sol-colv2__grid--item--image img{
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
      position: absolute;
      top: 0;
      left: 0;
  }
  .sol-colv2__grid--item--info{
      display: flex;
      justify-content: space-between;
      align-items: center;
  }
  .sol-colv2__grid--item--info .sol-colv2__grid--item--title{
      font-size: 20px;
      line-height: 1.5;
  }
  .sol-colv2__grid--item--info .sol-colv2__grid--item--cta{
      font-size: 13px;
      line-height: 30px;
      text-transform: uppercase;
      text-decoration: underline;
      text-underline-offset: 5px;
      color: #000;
  }
  @media screen and (max-width: 768px){
      .sol-colv2__container{
        padding: 25px 15px;
        padding-top:{{section.settings.padding_mobile_top}}px;
        padding-bottom:{{section.settings.padding_mobile_bottom}}px;
      }
      .sol-colv2__grid{
          grid-template-columns: 1fr;
          grid-column-gap: 0px;
          grid-row-gap: 25px;
      }
      .sol-colv2__grid--item{
          padding: 0;
      }
      .sol-colv2__grid--item--image{
          aspect-ratio: 1.15/1;
      }
  }
</style>
<div class="sol-colv2__container">
  <div class="sol-colv2__grid">
    <div class="sol-colv2__grid--item">
      <a href="/collections/{{ section.settings.col_1.handle }}" class="sol-colv2__grid--item--image">
        {% if section.settings.col_image_1 != blank %}
          <img
            src="{{ section.settings.col_image_1 | image_url }}"
            alt="{{ section.settings.col_1.title }}"
            width=""
            height=""
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </a>
      <div class="sol-colv2__grid--item--info">
        <div class="sol-colv2__grid--item--title">{{ section.settings.col_1.title }}</div>
        <a href="/collections/{{ section.settings.col_1.handle }}" class="sol-colv2__grid--item--cta">Shop Now</a>
      </div>
    </div>
    <div class="sol-colv2__grid--item">
      <a href="/collections/{{ section.settings.col_2.handle }}" class="sol-colv2__grid--item--image">
        {% if section.settings.col_image_2 != blank %}
          <img
            src="{{ section.settings.col_image_2 | image_url }}"
            alt="{{ section.settings.col_2.title }}"
            width=""
            height=""
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </a>
      <div class="sol-colv2__grid--item--info">
        <div class="sol-colv2__grid--item--title">{{ section.settings.col_2.title }}</div>
        <a href="/collections/{{ section.settings.col_2.handle }}" class="sol-colv2__grid--item--cta">Shop Now</a>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Sol Collection V2",
  "settings": [
    {
    "type": "text",
    "id": "title",
    "label": "Title",
    "default": "What's Trending"
    },
    {
      "type": "header",
      "content": "Collection 1"
    },
    {
      "type": "collection",
      "id": "col_1",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "col_image_1",
      "label": "Thumbnail"
    },
    {
      "type": "header",
      "content": "Collection 2"
    },
    {
      "type": "collection",
      "id": "col_2",
      "label": "Collection"
    },
    {
      "type": "image_picker",
      "id": "col_image_2",
      "label": "Thumbnail"
    },

    {
      "type": "range",
      "id": "padding_desktop_top",
      "label": "Padding Top (Desktop)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 125
    },
    {
      "type": "range",
      "id": "padding_desktop_bottom",
      "label": "Padding Bottom (Desktop)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_mobile_top",
      "label": "Padding Top (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_mobile_bottom",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 25
    }
  ],
  "presets": [
    {
      "name": "Sol Collection V2"
    }
  ]
}
{% endschema %}
