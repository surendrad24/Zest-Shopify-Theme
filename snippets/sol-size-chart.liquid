<style>
  .sol-chart__header{
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .sol-chart__title{
    font-size: 13px;
  }
  .sol-chart__toggles{
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: center;
  }
  .sol-chart__toggle{
    cursor: pointer;
  }
  .sol-chart__box{
    width: 10px;
    height: 10px;
    position: relative;
    border: 1px solid #D8D8D8;
    display: inline-block;
  }
  .sol-chart__box.active::before{
    content: "";
    width: 77%;
    height: 75%;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #000;
  }
  .sol-chart__label{
    font-size: 13px;
  }
  .sol-chart__body .sol-table{
    border-collapse: collapse;
    width: 100%;
    text-align: center;
    font-family: "syne";
    display: none;
  }
  .sol-chart__body .sol-table.active{
    display: table;
  }
  .sol-chart__body table th{
    padding: 6px;
    background: #f5f5f5;
    border: 1px solid #D8D8D8;
    font-size: 12px;
  }
  .sol-chart__body table td{
    padding: 7px 10px;
    border: 1px solid #D8D8D8;
    font-size: 12px;
  }
  .sol-chart__general .sol-table{
    display: table;
  }
  .sol-chart__conv{
    margin-top: 36px;
    margin-bottom: 18px;
  }
  .sol-chart__subtitle{
    font-size: 13px;
    margin-top: 16px;
  }
</style>
<!-- Drawer Overlay -->
<div
  id="drawerOverlay"
  style="
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    width: 100vw;
    background: rgba(0,0,0,0.2);
    z-index: 999;
    display: none;
  "
></div>

<!-- Drawer Panel -->
<div
  id="drawer"
  style="
    position: fixed;
    top: 0;
    right: -400px;
    width: 350px;
    max-width: 100%;
    height: 100vh;
    background: white;
    z-index: 1000;
    box-shadow: -2px 0 5px rgba(0,0,0,0.2);
    transition: right 0.5s ease;
    overflow-y: auto;
  "
>
  <div style="padding: 12px 14px; display: flex; align-items: center; border-bottom: 1px solid #D8D8D8;">
    <button
      id="closeDrawerBtn"
      style="background: none; border: none; font-size: 24px; cursor: pointer; padding: 0; height: auto;"
    >
      <svg width="25" height="7" viewBox="0 0 25 7" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" clip-rule="evenodd"
            d="M5.25 0.000244141L0 3.03133L5.25 6.06242V3.53133H25V2.53133H5.25V0.000244141Z"
            fill="black" />
      </svg>
    </button>
    <span style="margin-left: 10px; font-size: 14px;">Size Guide</span>
  </div>
  <!-- Content (you can paste the size guide image or tables here) -->
  <div style="padding: 16px;">
    {% comment %} Add your size guide HTML/image here {% endcomment %}
    <!--
      <img
        src="https://cdn.shopify.com/s/files/1/0724/5912/4972/files/Solandsand0Mayrange67.jpg?v=1748156578"
        alt="Size Guide"
        style="max-width: 100%;"
      >
    -->
