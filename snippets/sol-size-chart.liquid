    </div>
  </div>
</div>

<!-- Script -->
<script>
  document.getElementById('openDrawerBtn').addEventListener('click', function () {
    document.getElementById('drawerOverlay').style.display = 'block';
    document.getElementById('drawer').style.right = '0';
  });

  function closeDrawer() {
    document.getElementById('drawerOverlay').style.display = 'none';
    document.getElementById('drawer').style.right = '-400px';
  }

  document.getElementById('drawerOverlay').addEventListener('click', closeDrawer);
  document.getElementById('closeDrawerBtn').addEventListener('click', closeDrawer);


  document.addEventListener("DOMContentLoaded", ()=>{
    const elements = {
      centBtn: document.querySelector(".cent--botton"),
      inchBtn: document.querySelector(".inch--botton"),
      centTable: document.querySelector(".sol-table__cent"),
      inchTable: document.querySelector(".sol-table__inch")
    }
    elements.centBtn.addEventListener("click", ()=>{
      const box1 = elements.centBtn.querySelector('.sol-chart__box')
      const box2 = elements.inchBtn.querySelector('.sol-chart__box')
      if(!box1.classList.contains('active')){
        box1.classList.add('active')
      }
      if(box2.classList.contains('active')){
        box2.classList.remove('active')
      }

      if(!elements.centTable.classList.contains('active')){
        elements.centTable.classList.add('active')
      }
      if(elements.inchTable.classList.contains('active')){
        elements.inchTable.classList.remove('active')
      }
    })
    elements.inchBtn.addEventListener("click", ()=>{
      const box1 = elements.centBtn.querySelector('.sol-chart__box')
      const box2 = elements.inchBtn.querySelector('.sol-chart__box')
      if(box1.classList.contains('active')){
        box1.classList.remove('active')
      }
      if(!box2.classList.contains('active')){
        box2.classList.add('active')
      }

      if(elements.centTable.classList.contains('active')){
        elements.centTable.classList.remove('active')
      }
      if(!elements.inchTable.classList.contains('active')){
        elements.inchTable.classList.add('active')
      }
    })

  })
</script>
