<style>
  #cart-items::-webkit-scrollbar{
    width: 5px;
  }
  #cart-items::-webkit-scrollbar-track{
    background: #fff;
  }
  #cart-items::-webkit-scrollbar-thumb{
    background: #000;
    border-radius: 5px;
  }
</style>
<div
  id="exit-popup"
  style="
    display: none; position: fixed; top: 0; left: 0;
    width: 100%; height: 100%; background-color: rgba(0,0,0,0.6);
    z-index: 9999; justify-content: center; align-items: center;
  "
>
  <div style="background: white; padding: 20px; max-width: 500px; max-height: 80vh; overflow-y: auto;">
    <h2 style="text-align: center; font-size: 20px; margin-bottom: 10px;">Don’t Let These Deals Slip Away!</h2>
    <p style="text-align: center;">You’ve left items in your cart:</p>
    <div id="cart-items" style="margin: 15px 0; max-height: 200px; overflow-y: auto; padding: 0 10px;"></div>

    <div style="display: flex; justify-content: center; gap: 10px; margin-top: 20px; padding: 0 10px;">
      <button
        onclick="window.location.href='/checkout'"
        style="background: black; color: white; padding: 10px 15px; border: none; flex: 1;"
      >
        Go to Checkout
      </button>
      <button onclick="closeExitPopup()" style="padding: 10px 15px; border: 1px solid #000; flex: 1;">
        Keep Shopping
      </button>
    </div>
  </div>
</div>

<script>
  let idleTimer = null;
  let hasShownPopup = false;

  function formatMoney(cents) {
    // Shopify money formatting mimic: adjust per your shop currency settings
    return Shopify.formatMoney(cents, "{{ shop.money_format | escape }}");
  }

  function renderCartItems(items) {
    const container = document.getElementById('cart-items');
    container.innerHTML = '';

    items.forEach(item => {
      const itemEl = document.createElement('div');
      itemEl.style.display = 'flex';
      itemEl.style.alignItems = 'center';
      itemEl.style.marginBottom = '10px';
      itemEl.innerHTML = `
        <img src="${item.image}" alt="${item.title}" style="width: 80px; height: auto; object-fit: cover; margin-right: 10px;">
        <div style="flex: 1;">
          <div style="font-weight: 500;">${item.product_title}</div>
          <div style="color: #888;">${formatMoney(item.line_price)}</div>
        </div>
      `;
      container.appendChild(itemEl);
    });
  }

  function showExitPopup() {
    if (sessionStorage.getItem('exitPopupShown') === 'true') return;

    document.getElementById('exit-popup').style.display = 'flex';
  }

  function closeExitPopup() {
    document.getElementById('exit-popup').style.display = 'none';
    sessionStorage.setItem('exitPopupShown', 'true');
  }

  function resetIdleTimer() {
    clearTimeout(idleTimer);
    idleTimer = setTimeout(checkCartThenShowPopup, 15000); 
  }

  function checkCartThenShowPopup() {
     if (sessionStorage.getItem('exitPopupShown') === 'true') return;

    fetch('/cart.js')
      .then(res => res.json())
      .then(cart => {
        if (cart.items && cart.items.length > 0) {
          renderCartItems(cart.items);
          showExitPopup();
        }
      });
  }

  // Track user activity
  document.addEventListener('mousemove', resetIdleTimer);
  document.addEventListener('keydown', resetIdleTimer);
  document.addEventListener('scroll', resetIdleTimer);
  document.addEventListener('touchstart', resetIdleTimer); // mobile

  document.addEventListener('DOMContentLoaded', resetIdleTimer);
</script>
