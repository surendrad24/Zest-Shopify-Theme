{{ 'component-countdown-timer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'countdown-timer.js' | asset_url }}" defer="defer"></script>
{%- liquid 
  assign number_size = number_size | default: 'h3'
  assign type = type | default: 'fixed_time'
  assign duration = duration | default: 'every_month'
-%}
<countdown-timer 
  id="countdown-timer-{{ id }}"
  class="f-countdown-timer f-hidden no-js-hidden f-countdown-timer--{{ style | default: 'minimal' }}"
  data-type="{{ type }}"
  data-duration="{{ duration }}"
  data-due-date="{{ time }}"
>
    <div class="f-countdown-timer__inner inline-flex items-center justify-center">
        <div class="f-countdown-timer__block f-countdown-timer__spacing--{{ number_spacing | default: 'small' }}">
            <div class="f-countdown-timer__day {{ number_size }}" data-timer-day>00</div>
            <span class="text-subtext text-capitalize">{{ 'general.countdown-timer.days' | t }}</span>
        </div>
        <div class="f-countdown-timer__block f-countdown-timer__spacing--{{ number_spacing | default: 'small' }}">
            <div class="f-countdown-timer__hour {{ number_size }}" data-timer-hour>00</div>
            <span class="text-subtext text-capitalize">{{ 'general.countdown-timer.hours' | t }}</span>
        </div>
        <div class="f-countdown-timer__block f-countdown-timer__spacing--{{ number_spacing | default: 'small' }}">
            <div class="f-countdown-timer__minute {{ number_size }}" data-timer-minute>00</div>
            <span class="text-subtext text-capitalize">{{ 'general.countdown-timer.minutes' | t }}</span>
        </div>
        <div class="f-countdown-timer__block f-countdown-timer__spacing--{{ number_spacing | default: 'small' }}">
            <div class="f-countdown-timer__sec {{ number_size }}" data-timer-second>00</div>
            <span class="text-subtext text-capitalize">{{ 'general.countdown-timer.seconds' | t }}</span>
        </div>
    </div>
</countdown-timer>
